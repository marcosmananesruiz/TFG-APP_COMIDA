<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_titulo_direcciones"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titulo_direcciones"
        android:textColor="@color/text_color"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/et_nueva_direccion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/hint_nueva_direccion"
        android:textColor="@color/text_color"
        android:textColorHint="@color/text_color_secondary"
        app:layout_constraintEnd_toStartOf="@+id/btn_add_direccion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_titulo_direcciones" />

    <ImageButton
        android:id="@+id/btn_add_direccion"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_add_to_cart"
        app:layout_constraintBottom_toBottomOf="@+id/et_nueva_direccion"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/et_nueva_direccion"
        app:tint="@color/primary" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_direcciones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_nueva_direccion" />

    <TextView
        android:id="@+id/tv_no_direcciones"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_no_direcciones"
        android:textColor="@color/text_color_secondary"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_nueva_direccion" />

</androidx.constraintlayout.widget.ConstraintLayout>
