<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Cambiar Correo"
            android:textColor="@color/text_color"
            android:textSize="24sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Correo actual"
                    android:textColor="@color/text_color"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_mail_actual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Introduce tu correo actual"
                    android:textColor="@color/text_color"
                    android:textColorHint="@color/text_color"
                    android:alpha="0.6"
                    android:inputType="textEmailAddress" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nuevo correo electrónico"
                    android:textColor="@color/text_color"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_mail_nuevo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Introduce el nuevo correo"
                    android:textColor="@color/text_color"
                    android:textColorHint="@color/text_color"
                    android:alpha="0.6"
                    android:inputType="textEmailAddress" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_guardar_mail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/total_section_background"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_confirmar_mail"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CONFIRMAR CAMBIO"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
