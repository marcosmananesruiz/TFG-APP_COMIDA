<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/layout_confirmar"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Finalizar Pedido"
                android:textColor="@color/text_color"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Card Dirección -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Dirección de entrega"
                        android:textColor="@color/text_color"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_direccion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="Calle, número, piso..."
                        android:textColor="@color/text_color"
                        android:textColorHint="@color/text_color"
                        android:alpha="0.7"
                        android:inputType="textPostalAddress"
                        android:paddingVertical="8dp"
                        android:textSize="16sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Método de Pago -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Método de pago"
                        android:textColor="@color/text_color"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rg_metodo_pago"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/rb_tarjeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="Tarjeta de crédito/débito"
                            android:textColor="@color/text_color"
                            android:buttonTint="@color/primary"
                            android:checked="true" />

                        <RadioButton
                            android:id="@+id/rb_paypal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="PayPal"
                            android:textColor="@color/text_color"
                            android:buttonTint="@color/primary" />

                        <RadioButton
                            android:id="@+id/rb_efectivo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="Efectivo al repartidor"
                            android:textColor="@color/text_color"
                            android:buttonTint="@color/primary" />
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Datos Tarjeta -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_tarjeta_datos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Datos de la tarjeta"
                        android:textColor="@color/text_color"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_tarjeta_numero"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="Número de tarjeta"
                        android:textColor="@color/text_color"
                        android:textColorHint="@color/text_color"
                        android:alpha="0.7"
                        android:inputType="number"
                        android:paddingVertical="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/et_tarjeta_exp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="MM/AA"
                            android:textColor="@color/text_color"
                            android:textColorHint="@color/text_color"
                            android:alpha="0.7"
                            android:inputType="date"
                            android:paddingVertical="8dp" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/divider_color" />

                        <EditText
                            android:id="@+id/et_tarjeta_cvv"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="CVV"
                            android:textColor="@color/text_color"
                            android:textColorHint="@color/text_color"
                            android:alpha="0.7"
                            android:inputType="numberPassword"
                            android:paddingVertical="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Sección Inferior (Igual al carrito) -->
    <LinearLayout
        android:id="@+id/layout_confirmar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/total_section_background"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_confirmar_pedido"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CONFIRMAR PEDIDO"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
